# Copy to deploy.local.env and fill in real values. deploy.local.env is gitignored.

# Remote MotionEye
MOTIONEYE_URL=http://motioneye.example.local:8765
MOTIONEYE_USER=admin
MOTIONEYE_PASSWORD=changeme

# Shared SSO secret (must match the kukle-power SECRET_KEY)
SECRET_KEY=replace-with-shared-secret

# Auth behaviour
AUTH_ENABLED=true
KUKLE_POWER_LOGIN_URL=http://kukle-power.example.local/

# Host volumes
CONFIG_DIR=/host/path/to/DockerConfig/motioneye-proxy-gallery
MEDIA_ROOT=/host/path/to/motioneye

# Indexer tuning
INDEX_INTERVAL_SECONDS=900
REQUEST_TIMEOUT_MS=30000
MAX_RETRIES=5

# Portainer deploy (used by deploy.sh only)
PORTAINER_URL=http://portainer.example.local:9000/api
PORTAINER_API_KEY=replace-with-portainer-api-key
STACK_NAME=motioneye-proxy-gallery
